# Токен бота от @BotFather
BOT_TOKEN=your_telegram_bot_token

# PostgreSQL на alwaysdata (или другой хост)
# Вариант 1: одна строка (предпочтительно для alwaysdata)
DATABASE_URL=postgresql://USER:PASSWORD@postgresql-SERVER.alwaysdata.net:5432/DATABASE

# Вариант 2: отдельные переменные (если DATABASE_URL не задан)
# PGHOST=postgresql-superwomansocool.alwaysdata.net
# PGPORT=5432
# PGDATABASE=superwomansocool_test
# PGUSER=superwomansocool
# PGPASSWORD=your_password
